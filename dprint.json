{
  "lineWidth": 120,
  "indentWidth": 2,
  "useTabs": false,
  "newLineKind": "lf",
  "json": {
    "indentWidth": 2,
    "newLineKind": "lf",
    "trailingCommas": "never"
  },
  "markdown": {
    "lineWidth": 120,
    "textWrap": "maintain"
  },
  "includes": [
    "**/*.json",
    "**/*.md",
    "**/*.mdc"
  ],
  "excludes": [
    "node_modules",
    ".git",
    "LICENSE"
  ],
  "plugins": [
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm"
  ]
}
